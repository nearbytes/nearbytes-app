{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist-electron",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "electron"]
  },
  "include": ["electron/**/*.ts", "src/desktop/**/*.ts", "src/config/**/*.ts"],
  "exclude": ["node_modules", "dist", "dist-electron", "ui"]
}
